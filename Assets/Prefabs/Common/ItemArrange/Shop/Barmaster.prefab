  m_Name: 
  m_EditorClassIdentifier: 
  shopMessageDatas:
  - Key: Sikyu
    Messages:
    - "\u304A\u4EE3\u306F\u3044\u3089\u306A\u3044\u3088\u3002\n\u597D\u304D\u306A\u3060\u3051\u6301\u3063\u3066\u3044\u304D\u306A\u3002"
    - "\u3053\u3053\u306B\u3042\u308B\u3082\u306E\u306F\u5168\u90E8\u30BF\u30C0\u3060\u3002\n\u5B9F\u969B\u3001\u5927\u3057\u305F\u3082\u306E\u3058\u3083\u306A\u3044\u3055\u3002"
    - "\u4FE1\u4EF0\u5C5E\u6027\u304C\u4F7F\u3048\u308B\u306A\u3089\u3001\n\u300C\u4FE1\u4EF0\u306E\u62F3\u300D\u306F\u304A\u3059\u3059\u3081\u3060\u3088\u3002"
  - Key: Selling
    Messages:
    - "\u3053\u308C\u3089\u306F\u304A\u91D1\u3092\u3044\u305F\u3060\u304F\u3088\u3002\n\u6148\u5584\u4E8B\u696D\u3060\u3051\u3058\u3083\u306A\u3044\u304B\u3089\u306D\u3002"
    - "\u677E\u660E\u306F\u3001\u5165\u5834\u6642\u306B\u88C5\u5099\u3057\u3066\u3001\n\u5F8C\u306F\u5916\u3057\u3066\u3057\u307E\u3063\u3066\u3082\u3044\u3044\u3093\u3060\u3002"
  - Key: BuySikyu
    Messages:
    - "\u30C0\u30F3\u30B8\u30E7\u30F3\u306B\u884C\u304F\u306E\u304B\u3044\uFF1F\n\u7A3C\u3044\u3067\u304D\u306A\uFF01"
    - "\u5C11\u3005\u8CA0\u3051\u3066\u3082\u6B7B\u306B\u3084\u3057\u306A\u3044\u3002\n\u3053\u3053\u306B\u5E30\u3063\u3066\u3053\u3089\u308C\u308B\u3055\u3002"
  - Key: BuySelling
    Messages:
    - "\u304A\u76EE\u304C\u9AD8\u3044\uFF01\n\u306F\u3063\u3001\u8A00\u3063\u3066\u307F\u305F\u3060\u3051\u3055\u3002"
    - "\u9152\u3082\u8CB7\u3063\u3066\u3044\u304B\u306A\u3044\u304B\uFF1F"
  - Key: CharacterClicked
    Messages:
    - "\u79C1\u306F\u30D0\u30FC\u30DE\u30B9\u30BF\u30FC\u3002\n\u9152\u3068\u5192\u967A\u8005\u306E\u652F\u914D\u4EBA\u3060\u3002"
    - "\u3053\u306E\u571F\u5730\u306F\u30C0\u30F3\u30B8\u30E7\u30F3\u306B\u8FD1\u3044\u3002\n\u5371\u967A\u306F\u3042\u308B\u304C\u3001\u91D1\u306B\u306A\u308B\u3002"
    - "\u300C\u30E1\u30BF\u300D\u3068\u3044\u3046\u30EC\u30A2\u30EA\u30C6\u30A3\u304C\u3042\u308B\u3089\u3057\u3044\u3002\n\u30C0\u30F3\u30B8\u30E7\u30F3\u4E8C\u5C64\u306B\u884C\u304F\u3068\u51FA\u4F1A\u3048\u308B\u3068\u304B\u3002"
  messageText: {fileID: 2533995449208576372}
